# Copy to `.env` for local dev. Postgres via: docker compose up -d
DATABASE_URL=postgresql://barbro:barbro@localhost:5433/barbro

# Python for /api/analyze (optional)
# PYTHON=.venv/bin/python3

# Optional: HTTPS URL to desktop installers manifest JSON (same shape as /static/desktop-downloads.json).
# If unset, /download uses the built-in static manifest only.
# PUBLIC_DESKTOP_MANIFEST_URL=https://example.com/barbro/desktop-downloads.json
