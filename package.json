{
  "name": "fast_transcriber",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:clean": "rm -rf node_modules/.vite && vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "node scripts/migrate.mjs"
  },
  "devDependencies": {
    "@internationalized/date": "^3.12.0",
    "@lucide/svelte": "^1.7.0",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.1",
    "@types/pg": "^8.11.12",
    "bits-ui": "^2.16.5",
    "svelte": "^5.53.12",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "jspdf": "^4.2.1",
    "pg": "^8.14.1",
    "svg2pdf.js": "^2.7.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tw-animate-css": "^1.4.0",
    "vexflow": "^5.0.0"
  }
}
